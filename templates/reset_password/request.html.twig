{% extends 'base.html.twig' %}

{% block title %}Renitiliser mot de passe
{% endblock %}

{% block body %}


	<main class="main">

		<section id="contact" class="contact section">

			<div class="container">
				<div class="row  justify-content-center gy-4">

					<div class="col-11 col-md-10 col-lg-8 info-box">
						<div class="container section-title">
							<h1>Rénitialiser votre mot de passe</h1>
							<p class="mt-5">Entrez votre adresse email et nous vous enverrons un mail pour rénitialiser votre mot de passe</p>
						</div>
						<div class="inscription-form">
							{% for flash_error in app.flashes('reset_password_error') %}
								<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
							{% endfor %}


							{{ form_start(requestForm) }}

							{{ form_label(requestForm.email, 'Email') }}
							<div class="input-group mb-3">
								<span class="input-group-text">
									<i class="bi bi-envelope-at-fill"></i>
								</span>
								{{form_widget(requestForm.email,{
                                        'attr': {
                                            'class': 'form-control'
                                            
                                        }
                                    } )}}
							</div>
							

							<button class="btn button large mt-4">Envoyer</button>
							{{ form_end(requestForm) }}

						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
{% endblock %}
