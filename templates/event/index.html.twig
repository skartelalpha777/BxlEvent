{% extends 'base.html.twig' %}

{% block title %}
  Event index
{% endblock %}

{% block body %}
  <main class="main">
    <!-- Hero Section -->
    <section id="hero" class="hero section">
      <div class="container">
        <div class="row gy-4 align-items-center">
          <div class="col-lg-6 order-2 order-lg-1">
            <div class="hero-content">
              <h1>Bruxelles</h1>
              <h2>L'agenda de vos meilleures sorties</h2>
              <p">
                Concerts, expositions, festivals ou événements sportifs... <strong>BxlEvent</strong> rassemble pour vous toutes les activités incontournables de la capitale. Trouvez l'événement parfait, réservez vos billets en quelques clics et profitez pleinement de la vie bruxelloise.
              </p>
              <div class="hero-actions" data-aos="fade-up" data-aos-delay="500">
                <a href="portfolio.html" class="btn btn-primary">View My Work</a>
                <a href="contact.html" class="btn btn-outline">Get In Touch</a>
              </div>
              <div class="social-links" data-aos="fade-up" data-aos-delay="600">
                <a href="#"><i class="bi bi-twitter"></i></a>
                <a href="#"><i class="bi bi-linkedin"></i></a>
                <a href="#"><i class="bi bi-github"></i></a>
                <a href="#"><i class="bi bi-dribbble"></i></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- /Hero Section -->
  </main>

  <h1>Event index</h1>

  <table class="table">
    <thead>
      <tr>
        <th>Id</th>
        <th>Title</th>
        <th>Description</th>
        <th>Date</th>
        <th>Hour</th>
        <th>Status</th>
        <th>actions</th>
      </tr>
    </thead>
    <tbody>
      {% for event in events %}
        <tr>
          <td>{{ event.id }}</td>
          <td>{{ event.title }}</td>
          <td>{{ event.description }}</td>
          <td>{{ event.date ? event.date|date('Y-m-d') : '' }}</td>
          <td>{{ event.hour ? event.hour|date('H:i:s') : '' }}</td>
          <td>{{ event.status.value }}</td>
          <td>
            <a href="{{ path('app_event_show', { id: event.id }) }}">show</a>
            <a href="{{ path('app_event_edit', { id: event.id }) }}">edit</a>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="7">no records found</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <a href="{{ path('app_event_new') }}">Create new</a>
{% endblock %}
