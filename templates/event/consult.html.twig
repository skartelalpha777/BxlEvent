{% extends 'base.html.twig' %}

{% block title %}
	Consulter évènement
{% endblock %}

{% block body %}

	<main class="mainSection">

		<section id="hero">


			<div class="container">

				<div class="row">
					<div class="col-lg-9">
						<div id="carouselExample" class="carousel slide">
							<div class="carousel-inner">

								{% for eventimg in event.galleries %}
									{% set name = eventimg.filePath %}

									<div class="carousel-item {% if loop.first %}active{% endif %}">
										<img src="{{ asset('assets/img/uploads/events/') ~ name }}" class="d-block w-100" alt="...">
									</div>
								{% endfor %}


							</div>
							<button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
								<span class="carousel-control-prev-icon" aria-hidden="true"></span>
								<span class="visually-hidden">Previous</span>
							</button>
							<button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
								<span class="carousel-control-next-icon" aria-hidden="true"></span>
								<span class="visually-hidden">Next</span>
							</button>
						</div>
					</div>
					<div class="col">bbbbb</div>
				</div>

				<div class="row">
					<div class="col-6">cccc</div>
					<div class="col-6">dddd</div>
				</div>

				<div class="row">
					<div class="col">eeee</div>
					<div class="col">ffff</div>
				</div>

			</div>

		</section>

	</main>

{% endblock %}
